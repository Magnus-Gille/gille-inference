# Home-inference gateway configuration. Copy to .env, edit, and `chmod 600 .env`.
# NEVER commit a filled-in .env. Only SHA-256 hashes of minted keys are persisted;
# the values below are operator/runtime config.

# --- Network (keep loopback; Cloudflare Tunnel is the only inbound path) ---
HOMESERVER_HOST=127.0.0.1
HOMESERVER_PORT=8080

# --- Model backend (LM Studio today; llama-swap on arrival) ---
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
HOMESERVER_BACKEND=lmstudio          # "lmstudio" (default) | "llamaswap"
LLAMASWAP_BASE_URL=                  # llama-swap origin, e.g. http://127.0.0.1:8080 (overrides /v1 strip of LMSTUDIO_BASE_URL)

# --- Legacy static keys (OPTIONAL) ---
# The primary credentialing path is `keys mint` (per-friend, hashed, revocable).
# These env keys are a fallback. If set, they must be high-entropy (>=128 bits).
# Leave BOTH empty to use only minted store keys.
HOMESERVER_API_KEYS=
HOMESERVER_ADMIN_API_KEYS=

# --- Admission / best-effort behaviour ---
HOMESERVER_MAX_INFLIGHT=2            # global GPU slots; guests get 503 past this
HOMESERVER_OWNER_QUEUE_MAX_MS=5000   # owner request may queue this long before 503
HOMESERVER_BUSY_RETRY_AFTER_S=2      # Retry-After seconds on 503

# --- Per-request + per-key quota defaults (overridable per key at mint time) ---
HOMESERVER_MAX_TOKENS=12288          # default completion budget
HOMESERVER_PER_REQUEST_MAX_TOKENS=12288  # fleet default + ordinary-model hard cap
HOMESERVER_MODEL_MAX_TOKENS=vibethinker-3b=32768  # exact-model explicit-request ceilings; empty disables
HOMESERVER_KEY_DEFAULT_RPM=60        # requests/min for a new key
HOMESERVER_KEY_DEFAULT_TPM=60000     # tokens/min for a new key
HOMESERVER_KEY_DEFAULT_DAILY_TOKENS=0  # 0 = UNLIMITED. Set a real cap for guest keys!
HOMESERVER_KEY_DEFAULT_MAX_PARALLEL=1  # concurrent requests per key

# --- Public surface throttle (unauthenticated /portal, /portal/redeem) ---
# In-app per-IP sliding-window limit; defence-in-depth behind the Cloudflare WAF rule.
# Prefers the CF-Connecting-IP header (Cloudflare), else the socket address. 0 = disabled.
HOMESERVER_REDEEM_RPM=10             # max public-surface attempts per IP per window
HOMESERVER_PUBLIC_WINDOW_MS=600000   # window (ms) for the per-IP throttle (default 10 min)

# --- Access logging (structured JSON, one line per request) ---
HOMESERVER_ACCESS_LOG=on            # 'on' (default) | 'off'
HOMESERVER_ACCESS_LOG_HEALTHZ=off   # include /healthz hits in log: 'on' | 'off' (default)

# --- Image generation (text->image) ---
# LEAVE HOMESERVER_IMAGE_URL EMPTY to keep the whole image surface INERT (routes 404, no image-*
# advertised, no worker). Set it to a loopback sd-server (OpenAI /v1/images/generations) to enable.
HOMESERVER_IMAGE_URL=                 # e.g. http://127.0.0.1:8093  (empty = disabled)
HOMESERVER_IMAGE_MAX_N=4             # max images per request (n)
HOMESERVER_IMAGE_PROMPT_MAX_CHARS=2000
HOMESERVER_IMAGE_SIZES=512x512,768x768,1024x1024   # allowed sizes (comma-separated)
HOMESERVER_IMAGE_DEFAULT_SIZE=1024x1024
HOMESERVER_IMAGE_GPU_SLOTS=1         # concurrent diffusion jobs (only 1 supported today)
HOMESERVER_IMAGE_JOB_TIMEOUT_MS=300000   # per-job wall-clock ceiling (5 min)
HOMESERVER_IMAGE_RESULT_DIR=./data/image-results   # async result buffer (gitignored, TTL-swept)
HOMESERVER_IMAGE_RESULT_TTL_MS=3600000   # delete a finished job's bytes after this (1 h)
HOMESERVER_IMAGE_CREDITS_PER_IMAGE_FAST=5000       # credits per image, fast tier (sync)
HOMESERVER_IMAGE_CREDITS_PER_IMAGE_BALANCED=20000  # balanced tier (async)
HOMESERVER_IMAGE_CREDITS_PER_IMAGE_HIGH=60000      # high tier / FLUX (async)
HOMESERVER_IMAGE_MODEL_FAST=sdxl-turbo             # sidecar model id forwarded for image-fast
HOMESERVER_IMAGE_MODEL_BALANCED=sd3.5-large-turbo  # ... for image-balanced
HOMESERVER_IMAGE_MODEL_HIGH=flux.1-schnell         # ... for image-high (Apache-2.0 default)

# --- Misc ---
HOMESERVER_MIN_CONTEXT=32768
HOMESERVER_CALL_TIMEOUT_MS=600000
